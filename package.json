{
  "name": "fullpipe-mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build": "tsc --noEmit && vite build",
    "sync": "npm run build && cap sync android",
    "apk": "npm run sync && cd android && ./gradlew assembleDebug",
    "install-apk": "adb install -r android/app/build/outputs/apk/debug/app-debug.apk"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
